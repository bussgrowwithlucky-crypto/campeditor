# campeditor — environment template
#
# As of the all-local rewrite, this file is OPTIONAL. Everything below
# has a sane default; you only need to set values if you want to override.
# No API keys anywhere — the app runs entirely against a local Ollama
# daemon + faster-whisper for transcription.

# ─────────────────────────────────────────────────────────────────────────────
# Local Ollama — the ONLY external dependency.
# Install: https://ollama.com → `ollama serve`
# Pull:    ollama pull llava:13b   (vision)
#          ollama pull llama3.1:8b (text + chat)
# ─────────────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_VISION_MODEL=llava:13b
OLLAMA_TEXT_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=60
# How many concurrent in-flight Ollama requests to allow. The local GPU
# saturates at ~1-2 simultaneous inferences; more just uses RAM.
OLLAMA_MAX_CONCURRENCY=2

# ─────────────────────────────────────────────────────────────────────────────
# Whisper model for local transcription. large-v3 = best quality
# (~3 GB download, slow first run); medium/small = faster on CPU.
# ─────────────────────────────────────────────────────────────────────────────
WHISPER_MODEL=large-v3

# ─────────────────────────────────────────────────────────────────────────────
# FFmpeg / FFprobe — override only if not on PATH
# ─────────────────────────────────────────────────────────────────────────────
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# ─────────────────────────────────────────────────────────────────────────────
# yt-dlp auth for YouTube reference downloads
# Optional: provide a Netscape-format cookies.txt, otherwise yt-dlp tries Chrome
# ─────────────────────────────────────────────────────────────────────────────
YTDLP_COOKIES_FILE=data/youtube-cookies.txt
YTDLP_COOKIES_FROM_BROWSER=chrome

# ─────────────────────────────────────────────────────────────────────────────
# Storage + upload + clip-selection knobs (defaults are fine to start)
# ─────────────────────────────────────────────────────────────────────────────
BROLL_LIBRARY_DIR=data/broll_library
BROLL_QUERY_MAX_WORDS=8
BROLL_LOCAL_MATCH_THRESHOLD=0.35

CAMPEDITOR_DATA_DIR=data
CAMPEDITOR_MAX_UPLOAD_MB=500
CAMPEDITOR_AUTO_CLIP_SCAN_SECONDS=600
CAMPEDITOR_AUTO_CLIP_SCAN_TARGET_SECONDS=15
CAMPEDITOR_AUTO_CLIP_MIN_SECONDS=8
CAMPEDITOR_AUTO_CLIP_MAX_SECONDS=30