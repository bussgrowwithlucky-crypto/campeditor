# campeditor — environment template
#
# Vision + text + transcription all run against cloud APIs. No local model
# daemon (no Ollama, no faster-whisper). Every key below is optional — set
# only the providers you want enabled; unset providers degrade gracefully.

# ─────────────────────────────────────────────────────────────────────────────
# byNara Router — Vision + Text (primary LLM provider)
# Token-Plan key drives BOTH text (LLM_MODEL) and vision (LLM_VISION_MODEL)
# from one base URL. Telegram-gated: link Telegram + join required channels
# at https://router.bynara.id/settings, or the key 403s with
# "telegram_required".
# ─────────────────────────────────────────────────────────────────────────────
LLM_BASE_URL=https://router.bynara.id/v1
LLM_MODEL=mistral-large
LLM_VISION_MODEL=mistral-medium-3-5

# ─────────────────────────────────────────────────────────────────────────────
# Groq — Whisper transcription (audio -> text)
# https://console.groq.com/keys
# Primary key + optional backup. The transcription code rotates to
# GROQ_API_KEY_2 on 401/403/429 responses so a single exhausted key
# doesn't take the pipeline down.
# ─────────────────────────────────────────────────────────────────────────────
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo

# ─────────────────────────────────────────────────────────────────────────────
# Local Ollama — DISABLED. The cloud rungs above are the sole providers now;
# leave OLLAMA_* empty to skip the local rung entirely. The cloud path will
# be used and any failure surfaces immediately instead of silently falling
# back to Ollama.
# ─────────────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_VISION_MODEL=
OLLAMA_TEXT_MODEL=

# ─────────────────────────────────────────────────────────────────────────────
# FFmpeg / FFprobe — override only if not on PATH
# ─────────────────────────────────────────────────────────────────────────────
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# ─────────────────────────────────────────────────────────────────────────────
# yt-dlp auth for YouTube reference downloads
# Optional: provide a Netscape-format cookies.txt.
# Browser cookie extraction is disabled.
# ─────────────────────────────────────────────────────────────────────────────
YTDLP_COOKIES_FILE=data/youtube-cookies.txt
YTDLP_COOKIES_FROM_BROWSER=

# ─────────────────────────────────────────────────────────────────────────────
# Storage + upload + clip-selection knobs (defaults are fine to start)
# ─────────────────────────────────────────────────────────────────────────────
BROLL_LIBRARY_DIR=data/broll_library
BROLL_QUERY_MAX_WORDS=8
BROLL_LOCAL_MATCH_THRESHOLD=0.35

CAMPEDITOR_DATA_DIR=data
CAMPEDITOR_MAX_UPLOAD_MB=500
CAMPEDITOR_AUTO_CLIP_SCAN_SECONDS=600
CAMPEDITOR_AUTO_CLIP_SCAN_TARGET_SECONDS=15
CAMPEDITOR_AUTO_CLIP_MIN_SECONDS=8
CAMPEDITOR_AUTO_CLIP_MAX_SECONDS=30
